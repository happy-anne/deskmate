# ---- Supabase (required) ----
# Project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# ---- Firebase Cloud Messaging (optional — push notifications) ----
# Firebase console > Project settings > General (web app) + Cloud Messaging (VAPID)
NUXT_PUBLIC_FCM_API_KEY=
NUXT_PUBLIC_FCM_AUTH_DOMAIN=
NUXT_PUBLIC_FCM_PROJECT_ID=
NUXT_PUBLIC_FCM_MESSAGING_SENDER_ID=
NUXT_PUBLIC_FCM_APP_ID=
NUXT_PUBLIC_FCM_VAPID_KEY=
