# ---- Supabase (required) ----
# Project settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key

# ---- Web Push (VAPID) — push notifications ----
# Generate once:  npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=          # public key (also exposed to the client)
VAPID_PRIVATE_KEY=         # private key (server-only, keep secret)
VAPID_SUBJECT=mailto:you@example.com

# Server-only secrets used by /api/push/send (set in Vercel env):
# Service role key: Supabase > Project settings > API > service_role (secret!)
SUPABASE_SERVICE_ROLE_KEY=
# Shared secret between the Supabase DB webhook and the send route (any random string)
PUSH_WEBHOOK_SECRET=
